# Project Aura - Environment Configuration
# Copy to .env and update values for your environment
#
# Mode Detection:
# - If NEPTUNE_ENDPOINT is set → Neptune uses AWS mode
# - If OPENSEARCH_ENDPOINT is set → OpenSearch uses AWS mode
# - If AWS_REGION is set → DynamoDB uses AWS mode
# - Otherwise → Services use MOCK mode (in-memory)

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_REGION=us-east-1
ENVIRONMENT=dev
PROJECT_NAME=aura

# =============================================================================
# Neptune Graph Database (TLS Required)
# =============================================================================
# Cluster endpoint from: aws cloudformation describe-stacks --stack-name aura-neptune-dev
# NOTE: VPC-only endpoint - requires EKS deployment or VPN/bastion access
# Connection uses TLS/SSL (wss:// for WebSocket, https:// for REST)
NEPTUNE_ENDPOINT=aura-neptune-dev.cluster-EXAMPLE.us-east-1.neptune.amazonaws.com
NEPTUNE_PORT=8182
NEPTUNE_USE_SSL=true

# =============================================================================
# OpenSearch Vector Store (HTTPS Only)
# =============================================================================
# Domain endpoint from: aws cloudformation describe-stacks --stack-name aura-opensearch-dev
# NOTE: VPC-only endpoint - requires EKS deployment or VPN/bastion access
# Connection uses HTTPS (port 443)
OPENSEARCH_ENDPOINT=vpc-aura-dev-EXAMPLE.us-east-1.es.amazonaws.com
OPENSEARCH_PORT=443
OPENSEARCH_USE_SSL=true
VECTOR_DIMENSION=1024

# =============================================================================
# DynamoDB Tables (HTTPS via AWS SDK)
# =============================================================================
# Tables are regional - accessible with valid AWS credentials
# AWS SDK uses HTTPS by default for all DynamoDB operations
# Existing tables: aura-codebase-metadata-dev, aura-codegen-jobs-dev,
#                  aura-cost-tracking-dev, aura-user-sessions-dev
# NOTE: aura-ingestion-jobs-dev table needs to be created

# =============================================================================
# Git Ingestion
# =============================================================================
AURA_CLONE_PATH=/tmp/aura-repos
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
AURA_ALLOWED_BRANCHES=main,master,develop

# =============================================================================
# API Server
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO
