# Project Aura - Agent Orchestrator Container Image
#
# Multi-stage Dockerfile for the Agent Orchestrator service
# Coordinates Coder, Reviewer, and Validator agents
#
# Usage (Podman - primary per ADR-049):
#   podman build --platform linux/amd64 -t aura/agent-orchestrator:latest -f Dockerfile.orchestrator ../../..
#   podman run -p 8080:8080 aura/agent-orchestrator:latest
#
# Usage (Docker - CI/CD fallback):
#   docker build -t aura/agent-orchestrator:latest -f Dockerfile.orchestrator ../../..
#   docker run -p 8080:8080 aura/agent-orchestrator:latest

# ============================================================================
# Base Image Configuration
# ============================================================================
# Default to ECR Public Gallery for local development
# CI/CD overrides with private ECR via --build-arg for controlled supply chain
ARG PYTHON_BASE_IMAGE=public.ecr.aws/docker/library/python:3.11-slim

# ============================================================================
# STAGE 1: BUILDER
# ============================================================================

FROM ${PYTHON_BASE_IMAGE} AS builder

# Suppress debconf warnings in non-interactive builds
ENV DEBIAN_FRONTEND=noninteractive

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /build

# Pip security hardening and suppress script location warnings
ENV PIP_ROOT_USER_ACTION=ignore \
    PIP_NO_CACHE_DIR=true \
    PATH=/root/.local/bin:$PATH

# Copy dependency files
COPY requirements.txt .

# Install Python dependencies (suppress script warnings)
RUN pip install --no-cache-dir --user --no-warn-script-location -r requirements.txt

# ============================================================================
# STAGE 2: RUNTIME
# ============================================================================

FROM ${PYTHON_BASE_IMAGE} AS runtime

# Suppress debconf warnings in non-interactive builds
ENV DEBIAN_FRONTEND=noninteractive

# Install runtime dependencies only
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -u 1000 -s /bin/bash aura

# Set working directory
WORKDIR /app

# Copy Python dependencies from builder
COPY --from=builder /root/.local /home/aura/.local

# Copy application code
COPY src/ ./src/
COPY deploy/config/ ./config/

# Set ownership
RUN chown -R aura:aura /app

# Switch to non-root user
USER aura

# Add local bin to PATH
ENV PATH=/home/aura/.local/bin:$PATH

# Expose service port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Environment variables (can be overridden)
ENV PYTHONUNBUFFERED=1 \
    ENVIRONMENT=dev \
    LOG_LEVEL=INFO \
    PORT=8080

# Default command - HTTP server with SQS queue consumer (warm pool mode)
# For CLI mode, override with: python -m src.agents.agent_orchestrator
CMD ["python", "-m", "src.agents.orchestrator_server"]

# Metadata
LABEL maintainer="Project Aura Team" \
      description="Agent Orchestrator for Project Aura multi-agent system" \
      version="1.0.0" \
      org.opencontainers.image.source="https://github.com/project-aura/aura" \
      org.opencontainers.image.vendor="Project Aura" \
      org.opencontainers.image.title="Aura Agent Orchestrator"
