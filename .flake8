[flake8]
max-line-length = 140
# B008: Function calls in argument defaults (standard FastAPI pattern for Depends/Form/Query)
extend-ignore = E203, W503, E501, E402, B008
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info
per-file-ignores =
    tests/*:F401,F841
