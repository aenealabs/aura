{
  "ProjectName": "aura",
  "Environment": "prod",
  "DeploymentSize": "enterprise",
  "VpcCIDR": "10.0.0.0/16",

  "NeptuneInstanceType": "db.r6g.xlarge",
  "NeptuneBackupRetention": "14",
  "OpenSearchInstanceType": "r6g.xlarge.search",
  "OpenSearchVolumeSize": "100",
  "OpenSearchInstanceCount": "3",

  "EKSNodeInstanceType": "r6i.xlarge",
  "EKSNodeMinSize": "6",
  "EKSNodeMaxSize": "20",
  "NodeVolumeSize": "200",

  "KubernetesVersion": "1.34",
  "EnableDeletionProtection": "true",

  "EnableBedrock": "true",
  "PrimaryModel": "anthropic.claude-3-5-sonnet-20241022-v1:0",
  "EmbeddingModel": "amazon.titan-embed-text-v2:0",

  "_metadata": {
    "description": "Enterprise deployment configuration for 200+ developers",
    "estimated_monthly_cost": "$3,000-5,000",
    "recommended_for": "Large enterprises, mission-critical workloads",
    "neptune_mode": "provisioned",
    "high_availability": true,
    "multi_az": true,
    "features": [
      "Multi-AZ deployment",
      "Read replicas for Neptune",
      "Dedicated master nodes for OpenSearch",
      "Extended backup retention",
      "Larger EBS volumes",
      "Auto-scaling up to 20 nodes"
    ]
  }
}
