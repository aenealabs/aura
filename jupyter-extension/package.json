{
  "name": "@aura/jupyterlab-extension",
  "version": "2.0.0",
  "description": "Aura Code Intelligence for JupyterLab - Security scanning, GraphRAG context, and AI-powered fixes",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "security",
    "vulnerability",
    "ai",
    "code-intelligence",
    "graphrag"
  ],
  "homepage": "https://github.com/aenealabs/aura",
  "license": "BUSL-1.1",
  "author": {
    "name": "Aenea Labs"
  },
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,js,eot,gif,html,jpg,json,png,svg,woff2,ttf}"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/aenealabs/aura.git"
  },
  "scripts": {
    "build": "jlpm build:lib && jlpm build:labextension:dev",
    "build:prod": "jlpm clean && jlpm build:lib:prod && jlpm build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "clean": "jlpm clean:lib",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:labextension": "rimraf aura_jupyterlab/labextension aura_jupyterlab/_version.py",
    "clean:all": "jlpm clean:lib && jlpm clean:labextension",
    "eslint": "eslint . --ext .ts,.tsx --fix",
    "eslint:check": "eslint . --ext .ts,.tsx",
    "install:extension": "jlpm build",
    "lint": "jlpm eslint && jlpm prettier",
    "lint:check": "jlpm eslint:check && jlpm prettier:check",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prettier:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/cells": "^4.0.0",
    "@jupyterlab/codeeditor": "^4.0.0",
    "@jupyterlab/coreutils": "^6.0.0",
    "@jupyterlab/docregistry": "^4.0.0",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/rendermime": "^4.0.0",
    "@jupyterlab/services": "^7.0.0",
    "@jupyterlab/settingregistry": "^4.0.0",
    "@jupyterlab/ui-components": "^4.0.0",
    "@lumino/coreutils": "^2.0.0",
    "@lumino/messaging": "^2.0.0",
    "@lumino/signaling": "^2.0.0",
    "@lumino/widgets": "^2.0.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "@types/node": "^20.x",
    "@typescript-eslint/eslint-plugin": "^8.x",
    "@typescript-eslint/parser": "^6.x",
    "eslint": "^10.x",
    "eslint-config-prettier": "^9.x",
    "eslint-plugin-prettier": "^5.x",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.x",
    "rimraf": "^6.x",
    "typescript": "^5.x"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "aura_jupyterlab/labextension",
    "schemaDir": "schema",
    "disabledExtensions": []
  }
}
