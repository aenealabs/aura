# Project Aura - Linux Test Harness Container
#
# ============================================================================
# SCOPE: LOCAL-DEV ONLY -- DO NOT BAKE INTO SHARED IMAGES UNTIL ISSUE #195
# CLOSES.
#
# This image is intentionally built fresh by each developer (no registry
# push) and pinned with minor-version constraints on
# ``requirements-test-extras.txt`` rather than ``--require-hashes``. That's
# acceptable for the per-dev local-build model because the residual
# attack surface (compromised upstream wheel in a pinned minor range
# executing as UID 1000 against an RW bind-mount) is Medium severity --
# Sally's 2026-05-14 supply-chain review.
#
# Issue #195 tracks the Phase 2 promotion that lands the missing
# controls: private ECR base, CI-built shared image, hash-pinned
# dependencies, RO bind-mount + tmpfs for pytest write paths, SBOM +
# Sigstore via ADR-076. Until that issue closes, treat this image as
# a personal-dev artifact, NOT a shared one. Do NOT push it to any
# registry, do NOT bake it into a CI base image, do NOT reuse layers
# from it in a production build.
# ============================================================================
#
# Local-developer test harness that runs the pytest suite on a Linux
# runtime. Purpose: close the ~6,576 macOS-fork test skips caused by
# darwin's Objective-C runtime forbidding ``fork()`` after torch loads
# (see ``tests/conftest.py`` line 1042-1048 for the safety guard). On
# Linux there's no Objective-C runtime to taint, so ``pytest.mark.forked``
# tests run normally. Also preinstalls the optional-dep set from
# ``requirements-test-extras.txt`` to close ~62 more skips.
#
# Closures vs the 2026-05-14 darwin baseline:
#   - 6,576 macOS fork+torch     -> resolved by running on Linux
#   -    34 mypy-boto3-dynamodb  -> installed via requirements-test-extras
#   -    17 kubernetes           -> installed via requirements-test-extras
#   -     6 opentelemetry        -> installed via requirements-test-extras
#   -     4 cairosvg             -> installed via requirements-test-extras
#   -     1 hdbscan              -> installed via requirements-test-extras
# Not closed by this harness (independent issues):
#   -    18 CUDA tests (no NVIDIA hardware in the container)
#   -    10 API-server tests (need ``kubectl port-forward`` to live cluster)
#   -    14 ADR-093 placeholders (code not implemented yet)
#   -     3 z3-solver mock-path  (correctly skipped when real z3 present)
#   -   ~43 AWS E2E / Bedrock    (cost-gated per DEFERRED_WORK_REGISTRY)
#
# Usage (Podman - primary per ADR-049):
#   podman build --platform linux/amd64 \
#       -f deploy/docker/test-harness/Dockerfile.test-harness \
#       -t aura/test-harness:latest .
#   podman run --rm --platform linux/amd64 \
#       -v "$PWD":/workspace:Z \
#       -w /workspace \
#       aura/test-harness:latest \
#       pytest --no-cov -q
#
# Usage (Docker - CI fallback):
#   docker build -f deploy/docker/test-harness/Dockerfile.test-harness \
#       -t aura/test-harness:latest .
#
# Convenience: ``scripts/run-tests-in-container.sh`` wraps both build
# and run so the developer doesn't have to remember the flags.
#
# Memory: the test suite needs ~4-6 GB. On macOS, Podman Machine defaults
# to 2 GB -- bump it with ``podman machine set --memory 8192`` before
# first run.
#
# Base-image policy: defaults to the public ECR Gallery copy of
# ``python:3.11-slim`` so a developer with no AWS access can run the
# harness. CI / regulated builds override with the private ECR base via
# ``--build-arg PYTHON_BASE_IMAGE=...`` per the root CLAUDE.md Container
# Security section.

# NOTE: Python 3.12, not 3.11. The codebase uses 3.12-only syntax
# (e.g. PEP 701 f-strings containing backslashes -- see
# ``src/services/community_summarization_service.py:474``). The
# project's ``requires-python = ">=3.11"`` pin in pyproject.toml is
# laxer than the code actually supports; tighten that separately.
#
# Pinned by digest, not floating tag, so a malicious or accidental
# retag of ``:3.12-slim`` upstream can't change what every developer
# pulls on next rebuild. Bump the digest deliberately when picking
# up a new Python patch release; verify the new digest with
# ``podman inspect public.ecr.aws/docker/library/python:3.12-slim
# --format '{{ .Digest }}'``.
ARG PYTHON_BASE_IMAGE=public.ecr.aws/docker/library/python:3.12-slim@sha256:bf73779de6dbd030f3d189eeeb246286965832761ace318c1518300f76c0840d

FROM ${PYTHON_BASE_IMAGE} AS harness

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_ROOT_USER_ACTION=ignore \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# System deps:
#   build-essential  - hdbscan and a few other test extras compile native code
#   git              - some tests shell out to ``git`` (e.g. SWE-bench harness)
#   libcairo2        - cairosvg runtime dep (binding to system libcairo)
#   ca-certificates  - HTTPS to PyPI / model registries
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        ca-certificates \
        libcairo2 \
        libcairo2-dev \
        pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Stage the requirement files first so the dependency layer is cached
# across code edits (Dockerfile-best-practice ordering).
#
# Test-extras install uses ``--require-hashes`` against the lockfile
# generated by ``pip-compile --generate-hashes`` (issue #195 P3). Any
# transitive pulled into the install must match a SHA-256 hash in the
# lockfile -- a compromised upstream that publishes a malicious patch
# within our minor-version pin range fails fast with "hash mismatch"
# instead of silently shipping.
#
# Regenerate the lockfile (after editing ``requirements-test-extras.
# txt``) by running this inside the harness container:
#
#   podman run --rm --platform linux/amd64 -v "$PWD":/workspace \
#       -w /workspace -u root localhost/aura/test-harness:latest \
#       bash -c "pip install --quiet pip-tools && \
#                pip-compile --generate-hashes --no-strip-extras \
#                    --output-file requirements-test-extras.lock \
#                    requirements-test-extras.txt"
#
# ``requirements.txt`` does NOT yet have a hash-pinned lockfile;
# that's #195's larger scope (the main requirement set is much bigger
# and changes more often). Stays a follow-up.
COPY requirements.txt requirements-test-extras.lock /tmp/req/
RUN pip install --no-cache-dir -r /tmp/req/requirements.txt \
    && pip install --no-cache-dir --require-hashes \
        -r /tmp/req/requirements-test-extras.lock

# Run-time user. The harness ran as root on first cut, which is
# acceptable for a never-pushed local-dev image but unnecessary --
# pytest doesn't need privileged ops, and any test or transitively-
# imported module that misbehaves now lacks the ability to chown the
# repo, edit ``.git/hooks``, or write outside ``/workspace``. UID
# 1000 matches the typical macOS / Linux developer UID so bind-mount
# perms align without ``--user`` gymnastics.
RUN useradd --create-home --uid 1000 --shell /bin/bash aura
USER aura

# Default command runs the suite with coverage off; callers can override.
# The repo is expected to be bind-mounted at /workspace at run time --
# we deliberately do NOT ``COPY`` it into the image so the harness
# stays fast to rebuild and so test artifacts (e.g. cache files) are
# written back to the host.
CMD ["pytest", "--no-cov", "-q"]

LABEL org.opencontainers.image.title="Aura Test Harness" \
      org.opencontainers.image.description="Linux pytest harness that unblocks macOS-fork skips" \
      org.opencontainers.image.source="https://github.com/aenealabs/aura" \
      tier="non-production" \
      scope="test-harness" \
      attestation="https://aenealabs.com/attestations/v1"
