# Project Aura - RuntimeIncidentAgent Container Image (ADR-025)
#
# Autonomous incident investigation agent with code-aware RCA
# Runs as ECS Fargate task triggered by EventBridge
#
# Usage (Podman - primary per ADR-049):
#   podman build --platform linux/amd64 -t aura-runtime-incident-agent:latest -f Dockerfile.runtime-incident ../../..
#
# Usage (Docker - CI/CD fallback):
#   docker build --platform linux/amd64 -t aura-runtime-incident-agent:latest -f Dockerfile.runtime-incident ../../..
#
# Build Args:
#   - ENVIRONMENT: dev, qa, or prod (default: dev)
#

# ============================================================================
# Base Image Configuration
# ============================================================================
# Default to ECR Public Gallery for local development
# CI/CD overrides with private ECR via --build-arg for controlled supply chain
ARG PYTHON_BASE_IMAGE=public.ecr.aws/docker/library/python:3.11-slim

# ============================================================================
# STAGE 1: BUILDER
# ============================================================================

FROM ${PYTHON_BASE_IMAGE} AS builder

# Suppress debconf warnings in non-interactive builds
ENV DEBIAN_FRONTEND=noninteractive

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /build

# Pip security hardening and suppress script location warnings
ENV PIP_ROOT_USER_ACTION=ignore \
    PIP_NO_CACHE_DIR=true \
    PATH=/root/.local/bin:$PATH

# Copy dependency files
COPY requirements.txt .

# Install Python dependencies (suppress script warnings)
RUN pip install --no-cache-dir --user --no-warn-script-location -r requirements.txt

# ============================================================================
# STAGE 2: RUNTIME
# ============================================================================

FROM ${PYTHON_BASE_IMAGE} AS runtime

# Suppress debconf warnings in non-interactive builds
ENV DEBIAN_FRONTEND=noninteractive

# Build argument for environment
ARG ENVIRONMENT=dev

# Install runtime dependencies only
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -u 1000 -s /bin/bash aura

# Set working directory
WORKDIR /app

# Copy Python dependencies from builder
COPY --from=builder /root/.local /home/aura/.local

# Copy application code
COPY src/ ./src/
COPY deploy/config/ ./config/

# Copy entrypoint script
COPY deploy/docker/agents/entrypoint-runtime-incident.sh ./entrypoint.sh

# Set ownership and make entrypoint executable
RUN chown -R aura:aura /app && \
    chmod +x /app/entrypoint.sh

# Switch to non-root user
USER aura

# Add local bin to PATH
ENV PATH=/home/aura/.local/bin:$PATH

# Environment variables (can be overridden by ECS task definition)
ENV PYTHONUNBUFFERED=1 \
    ENVIRONMENT=${ENVIRONMENT} \
    LOG_LEVEL=INFO \
    AWS_DEFAULT_REGION=us-east-1

# No health check (ECS Fargate task, not long-running service)
# Task exits after investigation completes

# Entrypoint script handles argument parsing
ENTRYPOINT ["/app/entrypoint.sh"]

# Default command (can be overridden by ECS task)
CMD ["investigate"]

# Metadata
LABEL maintainer="Project Aura Team" \
      description="RuntimeIncidentAgent for code-aware incident response (ADR-025)" \
      version="1.0.0" \
      adr="ADR-025" \
      org.opencontainers.image.source="https://github.com/aenealabs/aura" \
      org.opencontainers.image.vendor="Aenea Labs" \
      org.opencontainers.image.title="Aura RuntimeIncidentAgent"
