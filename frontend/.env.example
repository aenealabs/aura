# Project Aura Frontend Configuration
# Copy this file to .env.local and update values as needed

# =============================================================================
# DEVELOPMENT MODE
# =============================================================================
# Set to 'true' to bypass Cognito authentication (uses mock user)
# This allows local development without AWS Cognito configured
# WARNING: Never set this to 'true' in production!
VITE_DEV_MODE=false

# Mock user configuration (only used when VITE_DEV_MODE=true)
# VITE_MOCK_USER_EMAIL=dev@aenealabs.com
# VITE_MOCK_USER_NAME=Developer
# VITE_MOCK_USER_ROLE=admin

# =============================================================================
# REQUIRED: Cognito Authentication (get from AWS Console or CloudFormation outputs)
# =============================================================================
# These values are REQUIRED for production. Local development will use defaults
# if not set when VITE_DEV_MODE=false.
# Get values from: aws ssm get-parameters-by-path --path /aura/dev/cognito

# Cognito User Pool ID (e.g., us-east-1_xxxxxxxxx)
VITE_COGNITO_USER_POOL_ID=

# Cognito App Client ID (no secret - public SPA client)
VITE_COGNITO_CLIENT_ID=

# Cognito Domain (for hosted UI, without https://)
# Example: aura-dev.auth.us-east-1.amazoncognito.com
VITE_COGNITO_DOMAIN=

# AWS Region for Cognito
VITE_COGNITO_REGION=us-east-1

# OAuth Redirect URLs (update for production)
VITE_REDIRECT_SIGN_IN=http://localhost:5173/auth/callback
VITE_REDIRECT_SIGN_OUT=http://localhost:5173/login

# =============================================================================
# API Configuration
# =============================================================================
# API URL - Backend FastAPI server
# For local development (proxied through Vite):
VITE_API_URL=/api/v1

# For direct backend connection:
# VITE_API_URL=http://localhost:8000/api/v1

# For production (EKS deployment):
# VITE_API_URL=https://api.aura.aenealabs.com/api/v1

# =============================================================================
# Other Configuration
# =============================================================================
# Reviewer email for approval actions
VITE_REVIEWER_EMAIL=reviewer@aenealabs.com
