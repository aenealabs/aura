# Project Aura - Generic Agent Container Image
#
# Multi-stage Dockerfile for Coder, Reviewer, and Validator agents
# Use build args to specify agent type at build time
#
# Uses requirements-agents.txt which includes:
#   - All API dependencies (requirements-api.txt)
#   - Tree-sitter for AST parsing
#   - Excludes torch (~1.8GB) - only needed for memory service
#
# Usage (Podman - primary per ADR-049):
#   podman build --platform linux/amd64 --build-arg AGENT_TYPE=coder -t aura/coder-agent:latest -f Dockerfile.agent ../../..
#   podman build --platform linux/amd64 --build-arg AGENT_TYPE=reviewer -t aura/reviewer-agent:latest -f Dockerfile.agent ../../..
#   podman build --platform linux/amd64 --build-arg AGENT_TYPE=validator -t aura/validator-agent:latest -f Dockerfile.agent ../../..
#
# Usage (Docker - CI/CD fallback):
#   docker build --build-arg AGENT_TYPE=coder -t aura/coder-agent:latest -f Dockerfile.agent ../../..
#   docker build --build-arg AGENT_TYPE=reviewer -t aura/reviewer-agent:latest -f Dockerfile.agent ../../..
#   docker build --build-arg AGENT_TYPE=validator -t aura/validator-agent:latest -f Dockerfile.agent ../../..

# ============================================================================
# Base Image Configuration
# ============================================================================
# Default to ECR Public Gallery for local development
# CI/CD overrides with private ECR via --build-arg for controlled supply chain
ARG PYTHON_BASE_IMAGE=public.ecr.aws/docker/library/python:3.11-slim

# ============================================================================
# STAGE 1: BUILDER
# ============================================================================

FROM ${PYTHON_BASE_IMAGE} AS builder

# Suppress debconf warnings in non-interactive builds
ENV DEBIAN_FRONTEND=noninteractive

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /build

# Pip security hardening and suppress script location warnings
ENV PIP_ROOT_USER_ACTION=ignore \
    PIP_NO_CACHE_DIR=true \
    PATH=/root/.local/bin:$PATH

# Copy agent-specific dependencies (includes API deps + tree-sitter, excludes torch)
COPY requirements-api.txt requirements-agents.txt ./

# Install Python dependencies (suppress script warnings)
# Using requirements-agents.txt reduces image size by ~2GB (excludes torch)
RUN pip install --no-cache-dir --user --no-warn-script-location -r requirements-agents.txt

# ============================================================================
# STAGE 2: RUNTIME
# ============================================================================

FROM ${PYTHON_BASE_IMAGE} AS runtime

# Suppress debconf warnings in non-interactive builds
ENV DEBIAN_FRONTEND=noninteractive

# Build argument for agent type (coder, reviewer, validator)
ARG AGENT_TYPE=coder

# Install runtime dependencies only
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -u 1000 -s /bin/bash aura

# Set working directory
WORKDIR /app

# Copy Python dependencies from builder
COPY --from=builder /root/.local /home/aura/.local

# Copy application code
COPY src/ ./src/
COPY deploy/config/ ./config/

# Set ownership
RUN chown -R aura:aura /app

# Switch to non-root user
USER aura

# Add local bin to PATH
ENV PATH=/home/aura/.local/bin:$PATH

# Expose service port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Environment variables (can be overridden)
ENV PYTHONUNBUFFERED=1 \
    ENVIRONMENT=dev \
    LOG_LEVEL=INFO \
    PORT=8080 \
    AGENT_TYPE=${AGENT_TYPE}

# Default command (agent type determined by build arg)
CMD python -m src.agents.${AGENT_TYPE}_agent

# Metadata
LABEL maintainer="Project Aura Team" \
      description="${AGENT_TYPE} agent for Project Aura multi-agent system" \
      version="1.0.0" \
      agent_type="${AGENT_TYPE}" \
      org.opencontainers.image.source="https://github.com/project-aura/aura" \
      org.opencontainers.image.vendor="Project Aura" \
      org.opencontainers.image.title="Aura ${AGENT_TYPE} Agent"
