{
  "ProjectName": "aura",
  "Environment": "dev",
  "DeploymentSize": "small",
  "VpcCIDR": "10.0.0.0/16",

  "NeptuneInstanceType": "db.t3.medium",
  "OpenSearchInstanceType": "t3.small.search",
  "OpenSearchVolumeSize": "20",
  "OpenSearchInstanceCount": "1",

  "EKSNodeInstanceType": "t3.medium",
  "EKSNodeMinSize": "1",
  "EKSNodeMaxSize": "3",
  "NodeVolumeSize": "50",

  "KubernetesVersion": "1.34",
  "EnableDeletionProtection": "false",

  "EnableBedrock": "true",
  "PrimaryModel": "anthropic.claude-3-5-sonnet-20241022-v1:0",
  "EmbeddingModel": "amazon.titan-embed-text-v2:0",

  "_metadata": {
    "description": "Internal DEV environment overlay (audit issue #187). Sized below 'small' customer tier because DEV gets aggressive off-hours scale-down via dev-cost-scheduler.yaml and gets torn down nightly via scripts/dev_killswitch.py.",
    "purpose": "internal staging, not a customer sizing tier",
    "neptune_mode": "provisioned",
    "high_availability": false,
    "multi_az": false,
    "deletion_protection": false,
    "cost_optimizations": [
      "EKSNodeMinSize=1 (down from 2 in small tier)",
      "Single-AZ",
      "Scaled to 0 nightly by dev-cost-scheduler.yaml",
      "Full teardown reachable via scripts/dev_killswitch.py"
    ]
  }
}
